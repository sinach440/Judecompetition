# Server (production webhook)
NODE_ENV=development
SERVER_URL=
WEBHOOK_PATH=/telegram-webhook
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bybit_affiliate

# Telegram
TELEGRAM_BOT_TOKEN=

# Bybit
BYBIT_API_KEY=
BYBIT_SECRET=
