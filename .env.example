# Affiliate & challenge
AFFILIATE_LINK=https://your-affiliate-link
VIP_GROUP_LINK=https://t.me/your_challenge_group
# Optional overrides (defaults are set in code if unset)
CHALLENGE_FORM_LINK=
TRANSFER_GUIDE_URL=
